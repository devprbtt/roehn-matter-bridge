CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
# Enable external PSRAM
CONFIG_SPIRAM_SUPPORT=y
CONFIG_SPIRAM_BOOT_INIT=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_TYPE_AUTO=y
# Route allocations >=8KB to PSRAM; keep small allocs (BLE EMI, DMA) in internal RAM
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=8192
# Increase maximum dynamic endpoints so the bridge can expose many discovered lights
CONFIG_ESP_MATTER_MAX_DYNAMIC_ENDPOINT_COUNT=128
