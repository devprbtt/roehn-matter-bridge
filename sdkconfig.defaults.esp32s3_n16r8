CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
# Enable external OPI PSRAM (N16R8 = 16MB flash + 8MB octal PSRAM)
CONFIG_ESP32S3_SPIRAM_SUPPORT=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_BOOT_INIT=y
CONFIG_SPIRAM_USE_MALLOC=y
# Allocations <8KB stay in internal DRAM (BLE EMI, DMA buffers)
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=512
# Route WiFi/LwIP heap to PSRAM to free internal RAM for BLE
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
# Move BSS/noinit segments marked for external memory into PSRAM to relieve DRAM
CONFIG_SPIRAM_ALLOW_BSS_SEG_EXTERNAL_MEMORY=y
CONFIG_SPIRAM_ALLOW_NOINIT_SEG_EXTERNAL_MEMORY=y
# Increase maximum dynamic endpoints so the bridge can expose many discovered lights
CONFIG_ESP_MATTER_MAX_DYNAMIC_ENDPOINT_COUNT=128
